# =============================================================================
# Plantilla de configuración. Copiar como .env y completar:  cp .env.example .env
# El .env real está en .gitignore (no se sube al repo).
# =============================================================================

# --- PROVEEDORES DE LLM (failover automático en este orden) -------------------
# Basta con tener UNA para arrancar. Cuando una se queda sin cuota, el grafo
# usa la siguiente que esté configurada.

# 1) Gemini (primario) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 2) Groq (alternativa gratis y muy rápida) — https://console.groq.com/keys
GROQ_API_KEY=

# 3) HuggingFace (inference API gratis) — https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=

# 4) LM Studio (modelo LOCAL, sin límite de cuota). Levantar el server local
#    en LM Studio (pestaña Developer -> Start Server) y dejar esta URL.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Orden de failover (opcional). Por defecto: gemini,groq,huggingface,lmstudio
# LLM_PROVIDER_ORDER=gemini,groq,huggingface,lmstudio

# Modelos por proveedor (opcional, ya hay defaults sensatos en llm.py)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct
# LMSTUDIO_MODEL=local-model

# --- OBSERVABILIDAD: LangSmith (opcional pero recomendado) --------------------
# Traces de cada decisión del agente. https://smith.langchain.com/ -> Settings -> API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente-consultorio
