# =============================================================================
# Plantilla de configuración. Copiar como .env y completar:  cp .env.example .env
# El .env real está en .gitignore (no se sube al repo).
# =============================================================================

# --- LM Studio (PROVEEDOR PRIMARIO: modelo local, sin límite de cuota) --------
# No requiere clave. Levantar el server local en LM Studio
# (pestaña Developer -> Start Server) con el modelo cargado (ej: gemma-4-e4b).
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=            # vacío => auto-detecta el modelo cargado en LM Studio

# --- Proveedores CLOUD (opcionales, failover si LM Studio no está disponible) -
# 1) Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# 2) Groq (gratis y rápido) — https://console.groq.com/keys
GROQ_API_KEY=
# 3) HuggingFace — https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=

# Orden de failover (opcional). Default: lmstudio,gemini,groq,huggingface
# LLM_PROVIDER_ORDER=lmstudio,gemini,groq,huggingface

# Modelos por proveedor (opcional, ya hay defaults en llm.py)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OBSERVABILIDAD: LangSmith (opcional pero recomendado) --------------------
# Traces de cada decisión del agente. https://smith.langchain.com/ -> Settings -> API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente-consultorio
